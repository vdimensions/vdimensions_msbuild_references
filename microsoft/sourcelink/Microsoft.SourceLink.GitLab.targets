<Project>
    <ItemGroup Condition=" '$(ManagePackageVersionsCentrally)' == 'true' ">
      <PackageVersion Include="Microsoft.SourceLink.GitLab" Version="10.0.201" />
    </ItemGroup>
    <ItemGroup Condition=" '$(ManagePackageVersionsCentrally)' != 'true' ">
      <PackageReference Update="Microsoft.SourceLink.GitLab" Version="10.0.201" />
    </ItemGroup>
</Project>
