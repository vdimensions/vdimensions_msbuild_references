<?xml version="1.0" encoding="utf-8"?>
<Project>
  <Choose>
    <!-- net -->
    <When Condition=" '$(TargetFramework)' == 'net8.0' ">
      <ItemGroup>
        <PackageReference Update="Microsoft.AspNetCore" Version="2.2.0" Condition=" '$(OutputType)' != 'Library' " />
        <PackageReference Update="Microsoft.AspNetCore" Version="2.0.0" Condition=" '$(OutputType)' == 'Library' " />
      </ItemGroup>
    </When>

    <When Condition=" '$(TargetFramework)' == 'net7.0' ">
      <ItemGroup>
        <PackageReference Update="Microsoft.AspNetCore" Version="2.2.0" Condition=" '$(OutputType)' != 'Library' " />
        <PackageReference Update="Microsoft.AspNetCore" Version="2.0.0" Condition=" '$(OutputType)' == 'Library' " />
      </ItemGroup>
    </When>

    <When Condition=" '$(TargetFramework)' == 'net6.0' ">
      <ItemGroup>
        <PackageReference Update="Microsoft.AspNetCore" Version="2.2.0" Condition=" '$(OutputType)' != 'Library' " />
        <PackageReference Update="Microsoft.AspNetCore" Version="2.0.0" Condition=" '$(OutputType)' == 'Library' " />
      </ItemGroup>
