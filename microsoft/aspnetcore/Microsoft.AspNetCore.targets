        <PackageReference Update="Microsoft.AspNetCore" Version="2.0.0" Condition=" '$(OutputType)' == 'Library' " />
      </ItemGroup>
    </When>

    <!-- netframework -->
    <When Condition=" '$(TargetFramework)' == 'net481' ">
