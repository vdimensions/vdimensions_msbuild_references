    <When Condition=" '$(TargetFramework)' == 'net47' ">
      <ItemGroup>
        <PackageReference Update="Microsoft.AspNetCore" Version="2.2.0" Condition=" '$(OutputType)' != 'Library' " />
        <PackageReference Update="Microsoft.AspNetCore" Version="2.0.0" Condition=" '$(OutputType)' == 'Library' " />
      </ItemGroup>
