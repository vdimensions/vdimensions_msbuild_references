        <PackageReference Update="Microsoft.AspNetCore" Version="2.0.0" Condition=" '$(OutputType)' == 'Library' " />
      </ItemGroup>
    </When>
    <When Condition=" '$(TargetFramework)' == 'netcoreapp1.1' ">
      <ItemGroup>
        <PackageReference Update="Microsoft.AspNetCore" Version="1.1.7" Condition=" '$(OutputType)' != 'Library' " />
        <PackageReference Update="Microsoft.AspNetCore" Version="1.1.0" Condition=" '$(OutputType)' == 'Library' " />
      </ItemGroup>
