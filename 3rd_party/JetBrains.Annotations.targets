<Project>
    <ItemGroup Condition=" '$(ManagePackageVersionsCentrally)' == 'true' ">
      <PackageVersion Include="JetBrains.Annotations" Version="2025.2.4" Condition=" '$(OutputType)' != 'Library' " />
      <PackageVersion Include="JetBrains.Annotations" Version="2022.3.1" Condition=" '$(OutputType)' == 'Library' " />
    </ItemGroup>
    <ItemGroup Condition=" '$(ManagePackageVersionsCentrally)' != 'true' ">
      <PackageReference Update="JetBrains.Annotations" Version="2025.2.4" Condition=" '$(OutputType)' != 'Library' " />
      <PackageReference Update="JetBrains.Annotations" Version="2022.3.1" Condition=" '$(OutputType)' == 'Library' " />
    </ItemGroup>
</Project>
