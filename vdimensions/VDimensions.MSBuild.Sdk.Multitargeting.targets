<Project>
    <ItemGroup Condition=" '$(ManagePackageVersionsCentrally)' == 'true' ">
      <PackageVersion Include="VDimensions.MSBuild.Sdk.Multitargeting" Version="0.7.7" />
    </ItemGroup>
    <ItemGroup Condition=" '$(ManagePackageVersionsCentrally)' != 'true' ">
      <PackageReference Update="VDimensions.MSBuild.Sdk.Multitargeting" Version="0.7.7" />
    </ItemGroup>
</Project>
