<Project>
    <ItemGroup Condition=" '$(ManagePackageVersionsCentrally)' == 'true' ">
      <PackageVersion Include="VDimensions.MSBuild.Sdk.Versioning" Version="0.6.12" />
    </ItemGroup>
    <ItemGroup Condition=" '$(ManagePackageVersionsCentrally)' != 'true' ">
      <PackageReference Update="VDimensions.MSBuild.Sdk.Versioning" Version="0.6.12" />
    </ItemGroup>
</Project>
